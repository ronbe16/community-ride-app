rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // retention handled server-side
    }

    // Trips — Addendum B: all authenticated users are immediately active
    match /trips/{tripId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.driverUid == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.driverUid == request.auth.uid;

      match /passengers/{passengerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null &&
          isOwner(passengerId);
        allow update, delete: if request.auth != null &&
          (isOwner(passengerId) || resource.data.driverUid == request.auth.uid);
      }
    }

    // Pending notifications — write-only for authenticated users (read/delete handled server-side)
    match /pending_notifications/{notifId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
