# Community Ride — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# ─── Firebase ────────────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Get your cloud name from cloudinary.com → Dashboard
# Upload preset must be named "community-ride" and set to UNSIGNED

VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=community-ride

# ─── Community Config ─────────────────────────────────────────────────────────
# Your community's display name — shown in the app header and on safety cards

VITE_COMMUNITY_NAME=My Village
